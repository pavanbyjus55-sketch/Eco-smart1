<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EcoSmart — Admin Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="css/main.css"/>
<style>
@keyframes slideIn { from { opacity:0; transform:translateX(40px); } to { opacity:1; transform:translateX(0); } }
@keyframes pulse   { 0%,100%{opacity:1} 50%{opacity:.3} }
</style>
</head>
<body>

<!-- AUTH SCREEN -->
<div id="authScreen">
  <div class="auth-wrap" style="background:#f8fafc">
    <div style="width:100%;max-width:420px">
      <a class="auth-back" href="index.html"><i class="fas fa-arrow-left"></i> Back to home</a>
      <div class="auth-card">
        <div class="auth-logo">
          <div class="auth-logo-icon" style="background:var(--blue)"><i class="fas fa-shield-alt" style="font-size:15px"></i></div>
          <div class="auth-logo-text">Admin <span style="color:var(--blue)">Portal</span></div>
        </div>
        <div class="auth-tabs">
          <button class="auth-tab active" id="tabA" onclick="switchTab('login')">Sign In</button>
          <button class="auth-tab"        id="tabB" onclick="switchTab('register')">Register</button>
        </div>

        <!-- LOGIN -->
        <div id="loginForm">
          <div class="auth-heading">Admin Login</div>
          <div class="auth-sub">Enter your username or email to sign in</div>
          <div class="error-msg" id="loginErr"></div>
          <div class="field">
            <label>Username or email</label>
            <input type="text" id="lCred" placeholder="admin or admin@ecosmart.com" autocomplete="username"/>
          </div>
          <div class="field">
            <label>Password</label>
            <input type="password" id="lPass" placeholder="Your password" autocomplete="current-password"
              onkeydown="if(event.key==='Enter')doLogin()"/>
          </div>
          <button class="btn btn-blue btn-full" id="loginBtn" onclick="doLogin()">
            <i class="fas fa-shield-alt"></i> Sign In
          </button>
          <div class="auth-footer">New admin? <a onclick="switchTab('register')">Register with admin key</a></div>
        </div>

        <!-- REGISTER -->
        <div id="regForm" style="display:none">
          <div class="auth-heading">Admin Registration</div>
          <div class="auth-sub">Create a new admin account using the registration key from your IT team</div>
          <div class="error-msg" id="regErr"></div>
          <div class="field-row">
            <div class="field">
              <label>Full name <span style="color:var(--red)">*</span></label>
              <input type="text" id="rName" placeholder="Your name"/>
            </div>
            <div class="field">
              <label>Username <span style="color:var(--red)">*</span></label>
              <input type="text" id="rUsername" placeholder="admin2" autocomplete="username"/>
            </div>
          </div>
          <div class="field-row">
            <div class="field">
              <label>Email <span style="color:var(--red)">*</span></label>
              <input type="email" id="rEmail" placeholder="admin@office.com"/>
            </div>
            <div class="field">
              <label>Phone <span style="color:var(--red)">*</span></label>
              <input type="tel" id="rPhone" placeholder="9876543210" maxlength="10"/>
            </div>
          </div>
          <div class="field">
            <label>Password <span style="color:var(--red)">*</span> <span style="font-size:11px;font-weight:400;color:var(--muted)">(min 6 chars)</span></label>
            <input type="password" id="rPass" placeholder="Create a password" autocomplete="new-password"/>
          </div>
          <div class="field">
            <label>Admin registration key <span style="color:var(--red)">*</span></label>
            <input type="password" id="rKey" placeholder="Get this from IT department"/>
          </div>
          <button class="btn btn-blue btn-full" id="regBtn" onclick="doRegister()">
            <i class="fas fa-user-shield"></i> Create Admin Account
          </button>
          <div class="auth-footer">Already registered? <a onclick="switchTab('login')">Sign in</a></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MAIN APP -->
<div id="appScreen" style="display:none">
  <div class="app-shell">
    <aside class="sidebar">
      <div class="sidebar-brand">
        <div class="sidebar-brand-icon" style="background:var(--blue)"><i class="fas fa-shield-alt" style="font-size:13px"></i></div>
        <div class="sidebar-brand-name">Admin <span style="color:#60a5fa">Panel</span></div>
      </div>
      <nav class="sidebar-nav">
        <div class="nav-group-label">Overview</div>
        <button class="nav-btn active" data-page="overview" onclick="goPage('overview')"><i class="fas fa-tachometer-alt"></i> Dashboard</button>
        <div class="nav-group-label">Manage</div>
        <button class="nav-btn" data-page="alerts" onclick="goPage('alerts')">
          <i class="fas fa-exclamation-triangle"></i> Sensor Alerts
          <span class="nav-count" id="navAlertCount" style="display:none">0</span>
        </button>
        <button class="nav-btn" data-page="reports" onclick="goPage('reports')">
          <i class="fas fa-flag"></i> User Reports
          <span class="nav-count" id="navReportCount" style="display:none">0</span>
        </button>
        <div class="nav-group-label">Monitor</div>
        <button class="nav-btn" data-page="bins"    onclick="goPage('bins')"><i class="fas fa-trash-alt"></i> Bin Monitor</button>
        <button class="nav-btn" data-page="sensors"  onclick="goPage('sensors')"><i class="fas fa-thermometer-half"></i> Sensor Readings</button>
        <button class="nav-btn" data-page="users"   onclick="goPage('users')"><i class="fas fa-users"></i> Users</button>
        <button class="nav-btn" data-page="profile" onclick="goPage('profile')"><i class="fas fa-user-circle"></i> My Profile</button>
      </nav>
      <div class="sidebar-footer">
        <div class="sidebar-profile">
          <div class="sidebar-avatar" id="sbAvatar" style="background:var(--blue)">A</div>
          <div>
            <div class="sidebar-profile-name"  id="sbName">Admin</div>
            <div class="sidebar-profile-email" id="sbRole">admin</div>
          </div>
        </div>
        <button class="btn btn-outline btn-full btn-sm" onclick="logout('index.html')"
          style="color:var(--sidebar-text);border-color:var(--sidebar-border)">
          <i class="fas fa-sign-out-alt"></i> Sign Out
        </button>
      </div>
    </aside>

    <div class="main-area">
      <div class="topbar">
        <div class="topbar-title" id="pageTitle">Dashboard</div>
        <div class="topbar-right">
          <!-- Notification bell -->
          <div class="notif-wrap">
            <button class="notif-toggle" id="notifToggleBtn" onclick="toggleNotif()">
              <i class="fas fa-bell"></i>
              <div class="notif-dot" id="notifDot"></div>
            </button>
            <div class="notif-panel" id="notifPanel">
              <div class="notif-head">
                Notifications
                <button onclick="markAllRead()">Mark all read</button>
              </div>
              <div id="notifList"><p style="text-align:center;color:var(--muted);padding:24px;font-size:13px">No notifications</p></div>
            </div>
          </div>
          <span id="liveLabel" style="font-size:12px;color:var(--muted)">Live</span>
        </div>
      </div>

      <!-- OVERVIEW -->
      <div id="pgOverview" class="page-wrap">
        <div class="page-head">
          <h1 id="greeting">Dashboard</h1>
          <p>Real-time system overview. Sensor alerts appear instantly when bins are full.</p>
        </div>
        <div class="stats-row">
          <div class="stat-box red">
            <div class="stat-label">Sensor Alerts</div>
            <div class="stat-val" id="ovAlerts">0</div>
            <div class="stat-hint">Unresolved</div>
          </div>
          <div class="stat-box amber">
            <div class="stat-label">User Reports</div>
            <div class="stat-val" id="ovReports">0</div>
            <div class="stat-hint">Pending review</div>
          </div>
          <div class="stat-box red">
            <div class="stat-label">Critical Bins</div>
            <div class="stat-val" id="ovCritical">0</div>
            <div class="stat-hint">Near overflow</div>
          </div>
          <div class="stat-box blue">
            <div class="stat-label">Registered Users</div>
            <div class="stat-val" id="ovUsers">0</div>
            <div class="stat-hint">Citizens</div>
          </div>
        </div>
        <!-- LIVE BIN LEVEL CARD — shows real-time Arduino data right on dashboard -->
        <div class="card" id="liveBinCard" style="border:2px solid #16a34a;margin-bottom:18px">
          <div class="card-title" style="margin-bottom:16px">
            <span style="display:flex;align-items:center;gap:8px">
              <span id="liveDot" style="width:10px;height:10px;border-radius:50%;background:#9ca3af;display:inline-block"></span>
              Live Bin — BIN001
            </span>
            <span id="liveLastUpdate" style="font-size:12px;color:var(--muted);font-weight:400">Waiting for Arduino...</span>
          </div>

          <!-- Big fill level display -->
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:14px;margin-bottom:18px">
            <div style="text-align:center;padding:16px 10px;background:#f9fafb;border-radius:10px;border:1px solid var(--border)">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:8px">Fill Level</div>
              <div id="liveFillNum" style="font-size:36px;font-weight:800;color:#16a34a;line-height:1">0%</div>
              <div id="liveFillStatus" style="font-size:12px;margin-top:4px;color:#16a34a;font-weight:600">Normal</div>
            </div>
            <div style="text-align:center;padding:16px 10px;background:#fff5f5;border-radius:10px;border:1px solid #fecaca">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#991b1b;margin-bottom:8px">Temperature</div>
              <div id="liveTempNum" style="font-size:36px;font-weight:800;color:#dc2626;line-height:1">—</div>
              <div style="font-size:12px;margin-top:4px;color:#991b1b">°C</div>
            </div>
            <div style="text-align:center;padding:16px 10px;background:#eff6ff;border-radius:10px;border:1px solid #bfdbfe">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#1d4ed8;margin-bottom:8px">Humidity</div>
              <div id="liveHumNum" style="font-size:36px;font-weight:800;color:#2563eb;line-height:1">—</div>
              <div style="font-size:12px;margin-top:4px;color:#1d4ed8">%</div>
            </div>
            <div style="text-align:center;padding:16px 10px;background:#f0fdf4;border-radius:10px;border:1px solid #bbf7d0">
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#166534;margin-bottom:8px">IR Sensor</div>
              <div id="liveIRNum" style="font-size:22px;font-weight:800;color:#16a34a;line-height:1;margin-top:6px">—</div>
              <div id="liveIRLabel" style="font-size:11px;margin-top:6px;color:#166534">Waiting</div>
            </div>
          </div>

          <!-- Fill level progress bar -->
          <div style="margin-bottom:8px">
            <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px">
              <span style="color:var(--muted)">Bin fill progress</span>
              <span id="liveFillLabel" style="font-weight:700;color:#16a34a">0% full</span>
            </div>
            <div style="height:16px;background:#f3f4f6;border-radius:8px;overflow:hidden">
              <div id="liveFillBar" style="height:100%;width:0%;background:#16a34a;border-radius:8px;transition:width .6s,background .3s"></div>
            </div>
          </div>

          <div id="liveLocation" style="font-size:12px;color:var(--muted);margin-top:8px">
            <i class="fas fa-map-marker-alt" style="margin-right:4px"></i>Lab Room, Building A
          </div>
        </div>

        <div class="card">
          <div class="card-title">
            Latest Sensor Alerts
            <button class="btn btn-outline btn-sm" onclick="goPage('alerts')">View all</button>
          </div>
          <div id="ovAlertPreview"><p style="color:var(--muted);font-size:14px">No active alerts.</p></div>
        </div>
        <div class="card">
          <div class="card-title">
            Latest User Reports
            <button class="btn btn-outline btn-sm" onclick="goPage('reports')">View all</button>
          </div>
          <div id="ovReportPreview"><p style="color:var(--muted);font-size:14px">No pending reports.</p></div>
        </div>
      </div>

      <!-- SENSOR ALERTS -->
      <div id="pgAlerts" class="page-wrap" style="display:none">
        <div class="page-head">
          <h1>Sensor Alerts</h1>
          <p>Real-time alerts from your Arduino. When IR sensor detects the bin is full, you see an instant alert here with location.</p>
        </div>
        <div class="filter-row">
          <button class="filter-chip active" onclick="filterAlerts('all',this)">All</button>
          <button class="filter-chip" onclick="filterAlerts('unresolved',this)">Unresolved</button>
          <button class="filter-chip" onclick="filterAlerts('resolved',this)">Resolved</button>
        </div>
        <div id="alertsList"></div>
      </div>

      <!-- USER REPORTS -->
      <div id="pgReports" class="page-wrap" style="display:none">
        <div class="page-head">
          <h1>User Reports</h1>
          <p>Problems reported by citizens — includes their name, email, phone and location.</p>
        </div>
        <div class="filter-row">
          <button class="filter-chip active" onclick="filterReports('all',this)">All</button>
          <button class="filter-chip" onclick="filterReports('pending',this)">Pending</button>
          <button class="filter-chip" onclick="filterReports('in_progress',this)">In Progress</button>
          <button class="filter-chip" onclick="filterReports('resolved',this)">Resolved</button>
        </div>
        <div id="reportsList"></div>
      </div>

      <!-- BIN MONITOR -->
      <div id="pgBins" class="page-wrap" style="display:none">
        <div class="page-head">
          <h1>Bin Monitor</h1>
          <p>Live fill levels from Arduino sensors. Data updates every time bridge.js sends a reading.</p>
        </div>
        <div class="bins-grid" id="adminBinsGrid"></div>
      </div>

      <!-- SENSOR READINGS -->
      <div id="pgSensors" class="page-wrap" style="display:none">
        <div class="page-head">
          <h1>Sensor Readings</h1>
          <p>Live temperature, humidity and fill level from your Arduino DHT11 sensor. Updates every 10 seconds.</p>
        </div>
        <div id="sensorGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px"></div>
      </div>

      <!-- USERS -->
      <div id="pgUsers" class="page-wrap" style="display:none">
        <div class="page-head"><h1>Registered Users</h1><p>All citizen accounts on the platform.</p></div>
        <div class="card">
          <div class="table-wrap">
            <table>
              <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>City</th><th>Joined</th><th>Last login</th></tr></thead>
              <tbody id="usersTable"><tr><td colspan="6" style="text-align:center;color:var(--muted);padding:24px">Loading...</td></tr></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- PROFILE -->
      <div id="pgProfile" class="page-wrap" style="display:none">
        <div class="page-head"><h1>My Profile</h1><p>Your admin account details.</p></div>
        <div class="profile-panel">
          <div class="profile-avatar" id="profileAvatar">A</div>
          <div>
            <div class="profile-info-name" id="profileName">Admin</div>
            <div class="profile-info-role">Administrator</div>
          </div>
        </div>
        <div class="card" style="max-width:500px">
          <div class="card-title">Account information</div>
          <table><tbody id="profileTable"></tbody></table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- UPDATE REPORT MODAL -->
<div class="modal-bg" id="reportModal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal()">&times;</button>
    <div class="modal-title" id="mTitle">Update Report</div>
    <div class="modal-sub"   id="mSub"></div>
    <input type="hidden" id="mId"/>
    <div class="reporter-box">
      <div class="rb-label">Reporter details</div>
      <div class="rb-grid">
        <div class="rb-item"><div class="rb-key">Name</div><div class="rb-val" id="mName">—</div></div>
        <div class="rb-item"><div class="rb-key">Phone</div><div class="rb-val" id="mPhone">—</div></div>
        <div class="rb-item"><div class="rb-key">Email</div><div class="rb-val" id="mEmail">—</div></div>
        <div class="rb-item"><div class="rb-key">City</div><div class="rb-val" id="mCity">—</div></div>
      </div>
      <div style="margin-top:8px"><div class="rb-key" style="font-size:11px">Location</div><div class="rb-val" id="mLocation" style="font-size:13px"></div></div>
      <div style="margin-top:6px"><div class="rb-key" style="font-size:11px">Description</div><div id="mDesc" style="font-size:13px;color:var(--ink2);line-height:1.5;margin-top:2px"></div></div>
    </div>
    <div class="field-row">
      <div class="field">
        <label>Status</label>
        <select id="mStatus">
          <option value="pending">Pending</option>
          <option value="in_progress">In Progress</option>
          <option value="resolved">Resolved</option>
          <option value="rejected">Rejected</option>
        </select>
      </div>
      <div class="field">
        <label>Priority</label>
        <select id="mPriority">
          <option value="low">Low</option>
          <option value="normal">Normal</option>
          <option value="high">High</option>
        </select>
      </div>
    </div>
    <div class="field">
      <label>Admin note <span style="font-size:12px;font-weight:400;color:var(--muted)">(shown to user)</span></label>
      <textarea id="mNote" rows="3" placeholder="e.g. Team dispatched. Issue resolved by Thursday."></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-green" style="flex:1" onclick="saveReport()">Save Changes</button>
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
    </div>
  </div>
</div>

<script src="js/utils.js"></script>
<script>
'use strict';
let adminUser = null;
let sAlerts   = [], uReports = [], allBins = [], notifs = [];
let alertFilt = 'all', reportFilt = 'all';
let ticker    = null, sse = null;

// ── AUTH ─────────────────────────────────────────────────────
function switchTab(tab) {
  const isLogin = tab === 'login';
  document.getElementById('loginForm').style.display = isLogin ? '' : 'none';
  document.getElementById('regForm').style.display   = isLogin ? 'none' : '';
  document.getElementById('tabA').classList.toggle('active', isLogin);
  document.getElementById('tabB').classList.toggle('active', !isLogin);
  document.getElementById('loginErr').style.display = 'none';
  document.getElementById('regErr').style.display   = 'none';
}

function showErr(el, msg) { el.textContent = msg; el.style.display = 'block'; }

async function doLogin() {
  const cred = document.getElementById('lCred').value.trim();
  const pass = document.getElementById('lPass').value;
  const err  = document.getElementById('loginErr');
  err.style.display = 'none';
  if (!cred) { showErr(err, 'Enter your username or email.'); return; }
  if (!pass) { showErr(err, 'Enter your password.');          return; }

  const btn = document.getElementById('loginBtn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Signing in...';
  const r = await apiFetch('/api/auth/admin/login', { method:'POST', body:JSON.stringify({ credential:cred, password:pass }) });
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-shield-alt"></i> Sign In';

  if (r.ok) { setToken(r.token); setUser(r.user); toast(r.message, 'success'); bootApp(r.user); }
  else { showErr(err, r.message || 'Login failed.'); }
}

async function doRegister() {
  const name  = document.getElementById('rName').value.trim();
  const uname = document.getElementById('rUsername').value.trim();
  const email = document.getElementById('rEmail').value.trim();
  const phone = document.getElementById('rPhone').value.trim();
  const pass  = document.getElementById('rPass').value;
  const key   = document.getElementById('rKey').value;
  const err   = document.getElementById('regErr');
  err.style.display = 'none';

  if (!name)  { showErr(err, 'Full name is required.');             return; }
  if (!uname) { showErr(err, 'Username is required.');              return; }
  if (!email) { showErr(err, 'Email is required.');                 return; }
  if (!phone) { showErr(err, 'Phone number is required.');          return; }
  if (!pass)  { showErr(err, 'Password is required.');              return; }
  if (!key)   { showErr(err, 'Admin registration key is required.'); return; }

  const btn = document.getElementById('regBtn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating...';
  const r = await apiFetch('/api/auth/register', { method:'POST', body:JSON.stringify({ name, username:uname, email, phone, password:pass, adminKey:key }) });
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-user-shield"></i> Create Admin Account';

  if (r.ok) { setToken(r.token); setUser(r.user); toast(r.message, 'success'); bootApp(r.user); }
  else { showErr(err, r.message || 'Registration failed. Check the admin key.'); }
}

// ── BOOT ─────────────────────────────────────────────────────
function bootApp(user) {
  adminUser = user;
  document.getElementById('authScreen').style.display = 'none';
  document.getElementById('appScreen').style.display  = '';
  document.getElementById('sbAvatar').textContent = user.name[0].toUpperCase();
  document.getElementById('sbName').textContent   = user.name;
  document.getElementById('sbRole').textContent   = user.username ? '@' + user.username : user.email;
  const h = new Date().getHours();
  document.getElementById('greeting').textContent =
    (h<12?'Good morning':h<17?'Good afternoon':'Good evening') + ', ' + user.name.split(' ')[0];
  loadAll();
  ticker = setInterval(loadAll, 15000);
  connectSSE();
}

// ── NAVIGATION ────────────────────────────────────────────────
const PAGE_NAMES = { overview:'Dashboard', alerts:'Sensor Alerts', reports:'User Reports', bins:'Bin Monitor', sensors:'Sensor Readings', users:'Users', profile:'My Profile' };
function goPage(name) {
  ['overview','alerts','reports','bins','sensors','users','profile'].forEach(p => {
    document.getElementById('pg' + p.charAt(0).toUpperCase() + p.slice(1)).style.display = p === name ? '' : 'none';
  });
  document.getElementById('pageTitle').textContent = PAGE_NAMES[name];
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.toggle('active', b.dataset.page === name));
  if (name === 'alerts')  renderAlerts();
  if (name === 'reports') renderReports();
  if (name === 'bins')    renderBins();
  if (name === 'sensors') loadSensors();
  if (name === 'users')   loadUsers();
  if (name === 'profile') renderProfile();
  document.getElementById('notifPanel').classList.remove('open');
}

// ── DATA ─────────────────────────────────────────────────────
async function loadAll() {
  const [rSum, rAlerts, rRep, rBins, rNotif] = await Promise.all([
    apiFetch('/api/admin/summary'),
    apiFetch('/api/admin/alerts'),
    apiFetch('/api/admin/reports'),
    apiFetch('/api/bins'),
    apiFetch('/api/admin/notifications')
  ]);

  if (rSum.ok) {
    const d = rSum.data;
    document.getElementById('ovAlerts').textContent   = d.alerts.unresolved;
    document.getElementById('ovReports').textContent  = d.reports.pending;
    document.getElementById('ovCritical').textContent = d.bins.critical;
    document.getElementById('ovUsers').textContent    = d.users.total;
    setBadge('navAlertCount',  d.alerts.unresolved);
    setBadge('navReportCount', d.reports.pending);
  }
  if (rAlerts.ok) { sAlerts  = rAlerts.data;  renderOverviewAlerts(); }
  if (rRep.ok)    { uReports = rRep.data;      renderOverviewReports(); }
  if (rBins.ok) {
    allBins = rBins.data;
    // Update live card with current data (important for first load after login)
    const bin001 = allBins.find(b => b.id === 'BIN001');
    if (bin001) updateLiveBinCard(bin001);
  }
  if (rNotif.ok)  {
    notifs = rNotif.data;
    document.getElementById('notifDot').classList.toggle('on', rNotif.unread > 0);
    renderNotifList();
  }
  document.getElementById('liveLabel').textContent = 'Updated ' + new Date().toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' });
}

async function loadUsers() {
  const r = await apiFetch('/api/admin/users');
  if (!r.ok) return;
  const citizens = r.data.filter(u => u.role === 'user');
  const tb = document.getElementById('usersTable');
  if (!citizens.length) { tb.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:24px">No users registered yet.</td></tr>'; return; }
  tb.innerHTML = citizens.map(u => `
    <tr>
      <td><b>${u.name}</b></td>
      <td>${u.email}</td>
      <td>${u.phone || '—'}</td>
      <td>${u.city  || '—'}</td>
      <td style="color:var(--muted)">${timeAgo(u.createdAt)}</td>
      <td style="color:var(--muted)">${u.lastLogin ? timeAgo(u.lastLogin) : 'Never'}</td>
    </tr>`).join('');
}

function setBadge(id, count) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.display = count > 0 ? '' : 'none';
  el.textContent   = count > 9 ? '9+' : count;
}

// ── OVERVIEW PREVIEWS ─────────────────────────────────────────
function renderOverviewAlerts() {
  const el  = document.getElementById('ovAlertPreview');
  const top = sAlerts.filter(a => !a.resolved).slice(0, 3);
  if (!top.length) { el.innerHTML = '<p style="color:var(--muted);font-size:14px">No active alerts right now.</p>'; return; }
  el.innerHTML = top.map(a => `
    <div style="display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid var(--border)">
      <div style="font-size:20px">&#128680;</div>
      <div style="flex:1">
        <div style="font-size:14px;font-weight:600">Bin ${a.binId} is full — please clear</div>
        <div style="font-size:12px;color:var(--muted);margin-top:2px"><i class="fas fa-map-marker-alt" style="color:var(--red)"></i> ${a.location} · Level: ${a.level}% · ${timeAgo(a.timestamp)}</div>
      </div>
      <span class="badge badge-critical">critical</span>
    </div>`).join('');
}

function renderOverviewReports() {
  const el  = document.getElementById('ovReportPreview');
  const top = uReports.filter(r => r.status === 'pending').slice(0, 3);
  if (!top.length) { el.innerHTML = '<p style="color:var(--muted);font-size:14px">No pending reports.</p>'; return; }
  el.innerHTML = top.map(r => `
    <div style="display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid var(--border)">
      <div style="flex:1">
        <div style="font-size:14px;font-weight:600">${r.category} — ${r.userName}</div>
        <div style="font-size:12px;color:var(--muted);margin-top:2px">${r.location} · ${timeAgo(r.createdAt)}</div>
      </div>
      <span class="badge badge-pending">pending</span>
    </div>`).join('');
}

// ── ALERTS PAGE ───────────────────────────────────────────────
function filterAlerts(f, btn) {
  alertFilt = f;
  document.querySelectorAll('#pgAlerts .filter-chip').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderAlerts();
}

function renderAlerts() {
  const el   = document.getElementById('alertsList');
  let   data = sAlerts;
  if (alertFilt === 'unresolved') data = data.filter(a => !a.resolved);
  if (alertFilt === 'resolved')   data = data.filter(a =>  a.resolved);
  if (!data.length) { el.innerHTML = '<p style="color:var(--muted);font-size:14px">No alerts in this category.</p>'; return; }

  el.innerHTML = data.map(a => {
    const isfire = a.kind === 'fire';
    const border = a.resolved ? 'var(--border)'                    : (isfire ? '#f97316' : '#dc2626');
    const bg     = a.resolved ? 'var(--color-background-primary)'  : (isfire ? '#fff7ed' : '#fff5f5');
    return `<div style="background:${bg};border:1.5px solid ${border};border-radius:12px;padding:18px 20px;margin-bottom:12px">
      <div style="display:flex;gap:14px;align-items:flex-start">
        <div style="font-size:26px;line-height:1;flex-shrink:0">${a.resolved ? '✅' : (isfire ? '🔥' : '🗑️')}</div>
        <div style="flex:1">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
            <div>
              <div style="font-size:15px;font-weight:700;color:var(--ink)">
                Dustbin ${a.binId} is full — please clear
                ${!a.resolved ? '<span style="color:#dc2626;animation:pulse 1.5s infinite;display:inline-block;margin-left:4px">●</span>' : ''}
              </div>
              <div style="font-size:12px;color:var(--muted);margin-top:2px">${timeAgo(a.timestamp)}</div>
            </div>
            <span style="background:${a.resolved?'var(--green-l)':'var(--red-l)'};color:${a.resolved?'#166534':'#991b1b'};font-size:11px;font-weight:700;padding:2px 9px;border-radius:10px;text-transform:uppercase;white-space:nowrap">${a.resolved ? 'Resolved' : 'Action needed'}</span>
          </div>
          <div style="background:rgba(0,0,0,.03);border-radius:8px;padding:12px 14px;margin-bottom:10px;font-size:13px;color:var(--ink2);line-height:1.7">
            <div><span style="color:var(--muted)">Bin ID:</span> <b>${a.binId}</b></div>
            <div><span style="color:var(--muted)">Fill level:</span> <b style="color:#dc2626">${a.level}%</b></div>
            <div style="display:flex;align-items:flex-start;gap:5px">
              <i class="fas fa-map-marker-alt" style="color:#dc2626;margin-top:2px;flex-shrink:0"></i>
              <span><b>Location:</b> ${a.address || a.location}</span>
            </div>
            ${a.lat ? `<div><span style="color:var(--muted)">GPS:</span> <span style="font-family:monospace;font-size:12px">${a.lat.toFixed(5)}, ${a.lng.toFixed(5)}</span></div>` : ''}
          </div>
          ${a.mapsLink ? `<a href="${a.mapsLink}" target="_blank" style="display:inline-flex;align-items:center;gap:5px;font-size:12px;color:#2563eb;font-weight:600;text-decoration:none;margin-bottom:10px"><i class="fas fa-map-marker-alt"></i> View on Google Maps</a>` : ''}
          ${a.resolved
            ? `<div style="font-size:12px;color:#166534;background:var(--green-l);border-radius:6px;padding:7px 12px">Resolved by ${a.resolvedBy} — ${timeAgo(a.resolvedAt)}</div>`
            : `<button class="btn btn-outline btn-sm" onclick="resolveAlert('${a.id}')"><i class="fas fa-check"></i> Mark as resolved</button>`
          }
        </div>
      </div>
    </div>`;
}

async function resolveAlert(id) {
  const r = await apiFetch('/api/admin/alerts/' + id + '/resolve', { method:'PATCH' });
  if (r.ok) {
    toast('Alert marked as resolved.', 'success');
    const a = sAlerts.find(a => a.id === id);
    if (a) { a.resolved = true; a.resolvedBy = adminUser.name; a.resolvedAt = new Date(); }
    renderAlerts();
    renderOverviewAlerts();
    await loadAll();
  } else { toast(r.message || 'Error resolving alert.', 'error'); }
}

// ── REPORTS PAGE ──────────────────────────────────────────────
function filterReports(f, btn) {
  reportFilt = f;
  document.querySelectorAll('#pgReports .filter-chip').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderReports();
}

function renderReports() {
  const el   = document.getElementById('reportsList');
  let   data = uReports;
  if (reportFilt !== 'all') data = data.filter(r => r.status === reportFilt);
  if (!data.length) { el.innerHTML = '<p style="color:var(--muted);font-size:14px">No reports in this category.</p>'; return; }
  el.innerHTML = data.map(r => `
    <div class="report-card">
      <div class="rc-top">
        <div>
          <div class="rc-category">${r.category}</div>
          <div class="rc-id">Report #${r.id.slice(-8)} &nbsp;·&nbsp; ${timeAgo(r.createdAt)}</div>
        </div>
        <span class="badge badge-${r.status}">${r.status.replace('_',' ')}</span>
      </div>
      <div class="rc-reporter">
        <div class="rr-item"><span class="rr-label">Name: </span><span class="rr-val">${r.userName}</span></div>
        <div class="rr-item"><span class="rr-label">Email: </span><span class="rr-val">${r.userEmail}</span></div>
        <div class="rr-item"><span class="rr-label">Phone: </span><span class="rr-val">${r.userPhone || 'Not provided'}</span></div>
        ${r.userCity ? `<div class="rr-item"><span class="rr-label">City: </span><span class="rr-val">${r.userCity}</span></div>` : ''}
      </div>
      <div class="rc-location">
        <i class="fas fa-map-marker-alt"></i>
        ${r.location}${r.address && r.address !== r.location ? ' &nbsp;·&nbsp; ' + r.address : ''}
        ${r.lat ? `<span style="font-family:monospace;font-size:11px;color:var(--muted)">(${r.lat.toFixed(4)}, ${r.lng.toFixed(4)})</span>` : ''}
      </div>
      <div class="rc-desc">${r.description}</div>
      ${r.adminNote ? `<div class="rc-admin-note"><i class="fas fa-comment"></i> Admin note: ${r.adminNote}</div>` : ''}
      <div class="rc-actions">
        <button class="btn btn-outline btn-sm" data-rid="${r.id}"><i class="fas fa-edit"></i> Update</button>
        ${r.status === 'pending' ? `<button class="btn btn-outline btn-sm" style="color:var(--green);border-color:#86efac" data-qrid="${r.id}"><i class="fas fa-check"></i> Resolve</button>` : ''}
      </div>
    </div>`).join('');

  el.querySelectorAll('[data-rid]').forEach(btn => {
    btn.onclick = () => { const r = uReports.find(x => x.id === btn.dataset.rid); if (r) openModal(r); };
  });
  el.querySelectorAll('[data-qrid]').forEach(btn => {
    btn.onclick = () => quickResolve(btn.dataset.qrid);
  });
}

// ── BINS ──────────────────────────────────────────────────────
// ── SENSOR READINGS PAGE ─────────────────────────────────────
async function loadSensors() {
  // Load current readings from server on page open
  // After this, SSE sensor_update events handle all real-time updates
  const r = await apiFetch('/api/sensor-readings');
  if (!r.ok) {
    document.getElementById('sensorGrid').innerHTML =
      '<p style="color:var(--muted)">Could not load sensor data. Is the server running?</p>';
    return;
  }
  renderSensorCards(r.data);
}

function renderSensorCards(readings) {
  const el = document.getElementById('sensorGrid');
  if (!el) return;

  // For SSE updates we get one bin at a time — update that card in place
  // For initial load we get all bins
  readings.forEach(b => {
    const existingCard = document.getElementById('sensorCard_' + b.id);
    const cardHtml = buildSensorCard(b);
    if (existingCard) {
      existingCard.outerHTML = cardHtml;
    } else {
      el.insertAdjacentHTML('beforeend', cardHtml);
    }
  });
}

function buildSensorCard(b) {
    const c       = binColor(b.level);
    const hasTemp = b.temp !== null && b.temp !== undefined && b.temp >= 0;
    const hasHum  = b.hum  !== null && b.hum  !== undefined && b.hum  >= 0;
    const temp    = hasTemp ? b.temp.toFixed(1) : '—';
    const hum     = hasHum  ? Math.round(b.hum) : '—';
    const tempColor = hasTemp && b.temp > 45 ? '#dc2626' : hasTemp && b.temp > 35 ? '#d97706' : '#16a34a';
    const humColor  = hasHum  && b.hum  > 80 ? '#dc2626' : hasHum  && b.hum  > 60 ? '#d97706' : '#2563eb';

    const irStatus = b.ir === 1 ? 'Detected (waste present)' : b.ir === 0 ? 'Clear (bin empty)' : '—';
    const irColor  = b.ir === 1 ? '#dc2626' : '#16a34a';

  return `<div id="sensorCard_${b.id}" style="background:white;border:1px solid var(--border);border-radius:12px;padding:20px;position:relative">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px">
        <div>
          <div style="font-size:14px;font-weight:700;color:var(--ink)">${b.id}</div>
          <div style="font-size:12px;color:var(--muted);margin-top:2px">${b.location}</div>
        </div>
        <span class="badge badge-${b.status}">${b.status}</span>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">

        <div style="background:#fff5f5;border:1px solid #fecaca;border-radius:9px;padding:12px;text-align:center">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#991b1b;margin-bottom:6px">
            Temperature
          </div>
          <div style="font-size:28px;font-weight:800;color:${tempColor};line-height:1">${temp}</div>
          <div style="font-size:12px;color:#991b1b;margin-top:2px">${hasTemp ? '°C' : 'No reading yet'}</div>
          ${hasTemp && b.temp > 45 ? '<div style="font-size:11px;color:#dc2626;margin-top:4px;font-weight:600">High temp warning!</div>' : ''}
        </div>

        <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:9px;padding:12px;text-align:center">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#1d4ed8;margin-bottom:6px">
            Humidity
          </div>
          <div style="font-size:28px;font-weight:800;color:${humColor};line-height:1">${hum}</div>
          <div style="font-size:12px;color:#1d4ed8;margin-top:2px">${hasHum ? '%' : 'No reading yet'}</div>
          ${hasHum && b.hum > 80 ? '<div style="font-size:11px;color:#dc2626;margin-top:4px;font-weight:600">High humidity!</div>' : ''}
        </div>

      </div>

      <div style="margin-bottom:10px">
        <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
          <span style="color:var(--muted)">Fill level</span>
          <span style="font-weight:700;color:${c}">${b.level}%</span>
        </div>
        <div style="height:8px;background:#f3f4f6;border-radius:4px;overflow:hidden">
          <div style="height:100%;width:${b.level}%;background:${c};border-radius:4px;transition:width .5s"></div>
        </div>
      </div>

      <div style="display:flex;align-items:center;gap:6px;font-size:12px;margin-bottom:6px">
        <span style="color:var(--muted)">IR sensor:</span>
        <span style="color:${irColor};font-weight:600">${irStatus}</span>
      </div>

      <div style="font-size:11px;color:var(--muted)">
        Last update: ${b.lastUpdated ? timeAgo(b.lastUpdated) : 'Waiting for Arduino...'}
      </div>

      ${!hasTemp && !hasHum ? '<div style="font-size:12px;color:#d97706;background:#fef3c7;border:1px solid #fcd34d;border-radius:7px;padding:8px 10px;margin-top:10px">Waiting for DHT11 data from Arduino. Make sure bridge.js is running.</div>' : ''}
    </div>`;
  }).join('');
}

function renderBins() {
  const el = document.getElementById('adminBinsGrid');
  if (!allBins.length) { el.innerHTML = '<p style="color:var(--muted)">No bins yet.</p>'; return; }
  el.innerHTML = allBins.map(b => {
    const c = binColor(b.level);
    return `<div class="bin-card ${b.status}">
      <div class="bin-id">${b.id} &nbsp;·&nbsp; ${b.type}</div>
      <div class="bin-loc">${b.location}</div>
      <div class="bin-bar"><div class="bin-fill" style="width:${b.level}%;background:${c}"></div></div>
      <div class="bin-footer" style="margin-bottom:6px">
        <span class="bin-pct" style="color:${c}">${Math.round(b.level)}%</span>
        <span class="badge badge-${b.status}">${b.status}</span>
      </div>
      <div style="font-size:11px;color:var(--muted)">Updated ${timeAgo(b.lastUpdated)}</div>
      ${b.status === 'critical' ? '<div style="font-size:11px;color:var(--red);margin-top:4px;font-weight:600">Alert sent to notifications</div>' : ''}
    </div>`;
  }).join('');
}

// ── PROFILE ───────────────────────────────────────────────────
async function renderProfile() {
  const r = await apiFetch('/api/auth/me');
  const u = r.ok ? r.user : adminUser;
  if (!u) return;
  document.getElementById('profileAvatar').textContent = u.name[0].toUpperCase();
  document.getElementById('profileName').textContent   = u.name;
  const rows = [
    ['Username', u.username || 'Not set'], ['Email', u.email],
    ['Phone', u.phone || 'Not set'], ['City', u.city || 'Not set'],
    ['Role', 'Administrator'],
    ['Account created', u.createdAt ? formatDate(u.createdAt) : 'N/A'],
    ['Last login', u.lastLogin ? formatDate(u.lastLogin) : 'This session']
  ];
  document.getElementById('profileTable').innerHTML = rows.map(([k,v]) =>
    `<tr><td style="color:var(--muted);width:160px;padding:10px 14px">${k}</td><td style="font-weight:600;padding:10px 14px">${v}</td></tr>`
  ).join('');
}

// ── MODAL ─────────────────────────────────────────────────────
function openModal(r) {
  if (!r) return;
  document.getElementById('mId').value       = r.id;
  document.getElementById('mTitle').textContent = r.category + ' — ' + r.userName;
  document.getElementById('mSub').textContent   = 'Report #' + r.id.slice(-8) + '  ·  ' + timeAgo(r.createdAt);
  document.getElementById('mName').textContent  = r.userName;
  document.getElementById('mPhone').textContent = r.userPhone || 'Not provided';
  document.getElementById('mEmail').textContent = r.userEmail;
  document.getElementById('mCity').textContent  = r.userCity  || 'Not specified';
  document.getElementById('mLocation').textContent = r.location + (r.address && r.address !== r.location ? '  ·  ' + r.address : '');
  document.getElementById('mDesc').textContent  = r.description;
  document.getElementById('mStatus').value   = r.status;
  document.getElementById('mPriority').value = r.priority || 'normal';
  document.getElementById('mNote').value     = r.adminNote || '';
  document.getElementById('reportModal').classList.add('open');
}

function closeModal() { document.getElementById('reportModal').classList.remove('open'); }
document.getElementById('reportModal').addEventListener('click', e => {
  if (e.target === document.getElementById('reportModal')) closeModal();
});

async function saveReport() {
  const id        = document.getElementById('mId').value;
  const status    = document.getElementById('mStatus').value;
  const priority  = document.getElementById('mPriority').value;
  const adminNote = document.getElementById('mNote').value.trim();
  const r = await apiFetch('/api/admin/reports/' + id, { method:'PATCH', body:JSON.stringify({ status, priority, adminNote }) });
  if (r.ok) {
    toast('Report updated.', 'success');
    closeModal();
    const idx = uReports.findIndex(x => x.id === id);
    if (idx !== -1) uReports[idx] = r.data;
    renderReports();
    await loadAll();
  } else { toast(r.message || 'Error.', 'error'); }
}

async function quickResolve(id) {
  const r = await apiFetch('/api/admin/reports/' + id, { method:'PATCH', body:JSON.stringify({ status:'resolved', adminNote:'Resolved by admin.' }) });
  if (r.ok) {
    toast('Report resolved.', 'success');
    const idx = uReports.findIndex(x => x.id === id);
    if (idx !== -1) uReports[idx] = r.data;
    renderReports();
    await loadAll();
  } else { toast(r.message || 'Error.', 'error'); }
}

// ── NOTIFICATIONS ─────────────────────────────────────────────
function toggleNotif() { document.getElementById('notifPanel').classList.toggle('open'); }
document.addEventListener('click', e => {
  const wrap = document.querySelector('.notif-wrap');
  if (wrap && !wrap.contains(e.target)) document.getElementById('notifPanel').classList.remove('open');
});

function renderNotifList() {
  const el = document.getElementById('notifList');
  if (!notifs.length) { el.innerHTML = '<p style="text-align:center;color:var(--muted);padding:24px;font-size:13px">No notifications</p>'; return; }
  const icons = { alert:'&#128680;', report:'&#128203;', system:'&#8505;' };
  el.innerHTML = notifs.slice(0, 25).map(n => `
    <div class="notif-item ${n.read?'':'unread'}" data-nid="${n.id}">
      <div class="notif-icon">${icons[n.type] || '&#128276;'}</div>
      <div style="flex:1">
        <div class="notif-title">${n.title}</div>
        <div class="notif-body">${n.body}</div>
        <div class="notif-time">${timeAgo(n.timestamp)}</div>
      </div>
      ${!n.read ? '<div class="notif-unread-dot"></div>' : ''}
    </div>`).join('');

  el.querySelectorAll('[data-nid]').forEach(item => {
    item.onclick = async () => {
      const id = item.dataset.nid;
      await apiFetch('/api/admin/notifications/' + id + '/read', { method:'PATCH' });
      item.classList.remove('unread');
      item.querySelector('.notif-unread-dot')?.remove();
      const n = notifs.find(x => x.id === id);
      if (n) n.read = true;
      const unread = notifs.filter(x => !x.read).length;
      document.getElementById('notifDot').classList.toggle('on', unread > 0);
    };
  });
}

async function markAllRead() {
  await apiFetch('/api/admin/notifications/read-all', { method:'PATCH' });
  notifs.forEach(n => n.read = true);
  document.getElementById('notifDot').classList.remove('on');
  renderNotifList();
  toast('All notifications read.', 'success');
}

// ── UPDATE LIVE BIN CARD ON DASHBOARD ────────────────────────
function updateLiveBinCard(b) {
  // Fill level number and bar
  const level = Math.round(b.level || 0);
  const fillColor = level >= 90 ? '#dc2626' : level >= 70 ? '#d97706' : '#16a34a';
  const statusText = level >= 90 ? 'FULL — Alert sent!' : level >= 70 ? 'Warning — getting full' : 'Normal';

  const fillNum = document.getElementById('liveFillNum');
  const fillBar = document.getElementById('liveFillBar');
  const fillLabel = document.getElementById('liveFillLabel');
  const fillStatus = document.getElementById('liveFillStatus');
  if (fillNum)    { fillNum.textContent = level + '%'; fillNum.style.color = fillColor; }
  if (fillBar)    { fillBar.style.width = level + '%'; fillBar.style.background = fillColor; }
  if (fillLabel)  { fillLabel.textContent = level + '% full'; fillLabel.style.color = fillColor; }
  if (fillStatus) { fillStatus.textContent = statusText; fillStatus.style.color = fillColor; }

  // Temperature
  const tempEl = document.getElementById('liveTempNum');
  if (tempEl) {
    if (b.temp !== null && b.temp !== undefined && b.temp >= 0) {
      tempEl.textContent = parseFloat(b.temp).toFixed(1);
      tempEl.style.color = b.temp > 45 ? '#dc2626' : b.temp > 35 ? '#d97706' : '#dc2626';
    } else {
      tempEl.textContent = '—';
    }
  }

  // Humidity
  const humEl = document.getElementById('liveHumNum');
  if (humEl) {
    if (b.hum !== null && b.hum !== undefined && b.hum >= 0) {
      humEl.textContent = Math.round(b.hum);
      humEl.style.color = b.hum > 80 ? '#dc2626' : b.hum > 60 ? '#d97706' : '#2563eb';
    } else {
      humEl.textContent = '—';
    }
  }

  // IR sensor
  const irEl    = document.getElementById('liveIRNum');
  const irLabel = document.getElementById('liveIRLabel');
  if (irEl && irLabel) {
    if (b.ir === 1) {
      irEl.textContent   = 'YES';
      irEl.style.color   = '#dc2626';
      irLabel.textContent = 'Waste detected';
      irLabel.style.color = '#991b1b';
    } else if (b.ir === 0) {
      irEl.textContent   = 'NO';
      irEl.style.color   = '#16a34a';
      irLabel.textContent = 'Bin clear';
      irLabel.style.color = '#166534';
    }
  }

  // Live dot — green pulsing = connected
  const dot = document.getElementById('liveDot');
  if (dot) { dot.style.background = '#16a34a'; dot.style.animation = 'pulse 1.5s infinite'; }

  // Last update time
  const upd = document.getElementById('liveLastUpdate');
  if (upd) upd.textContent = 'Updated ' + new Date().toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit',second:'2-digit'});

  // Location
  const locEl = document.getElementById('liveLocation');
  if (locEl && b.location) locEl.innerHTML = '<i class="fas fa-map-marker-alt" style="margin-right:4px"></i>' + b.location;

  // Card border color changes with status
  const card = document.getElementById('liveBinCard');
  if (card) {
    card.style.borderColor = level >= 90 ? '#dc2626' : level >= 70 ? '#d97706' : '#16a34a';
  }
}

// ── SSE CONNECTION ────────────────────────────────────────────
function connectSSE() {
  if (sse) { sse.close(); sse = null; }
  const token = getToken();
  if (!token) return;

  sse = new EventSource('/api/events?token=' + encodeURIComponent(token));

  sse.addEventListener('connected', e => {
    const d = JSON.parse(e.data);
    if (d.unread > 0) document.getElementById('notifDot').classList.add('on');
    document.getElementById('liveLabel').textContent = 'Live';
  });

  // Instant alert from Arduino sensor
  sse.addEventListener('alert', e => {
    const alert = JSON.parse(e.data);
    if (!sAlerts.find(a => a.id === alert.id)) sAlerts.unshift(alert);
    showAlertPopup(alert);
    const unresolved = sAlerts.filter(a => !a.resolved).length;
    document.getElementById('ovAlerts').textContent = unresolved;
    setBadge('navAlertCount', unresolved);
    renderOverviewAlerts();
    const pgAlerts = document.getElementById('pgAlerts');
    if (pgAlerts && pgAlerts.style.display !== 'none') renderAlerts();
  });

  // Instant notification
  sse.addEventListener('notification', e => {
    const n = JSON.parse(e.data);
    if (!notifs.find(x => x.id === n.id)) notifs.unshift(n);
    document.getElementById('notifDot').classList.add('on');
    renderNotifList();
  });

  sse.addEventListener('alert_resolved', e => {
    const { id } = JSON.parse(e.data);
    const a = sAlerts.find(a => a.id === id);
    if (a) { a.resolved = true; a.resolvedBy = adminUser.name; a.resolvedAt = new Date(); }
  });

  // Real-time sensor update from Arduino — server pushes this every 5 seconds
  sse.addEventListener('sensor_update', e => {
    const update = JSON.parse(e.data);

    // 1. Update allBins array
    const binIdx = allBins.findIndex(b => b.id === update.id);
    if (binIdx !== -1) allBins[binIdx] = { ...allBins[binIdx], ...update };
    else allBins.push(update);

    // 2. Update the BIG live bin card on the Dashboard — always, regardless of active page
    updateLiveBinCard(update);

    // 3. Update critical bin count
    const critical = allBins.filter(b => b.status === 'critical').length;
    const critEl = document.getElementById('ovCritical');
    if (critEl) critEl.textContent = critical;

    // 4. If Sensor Readings page is visible, update it too
    const pgSensors = document.getElementById('pgSensors');
    if (pgSensors && pgSensors.style.display !== 'none') renderSensorCards([update]);

    // 5. If Bin Monitor page is visible, update it too
    const pgBins = document.getElementById('pgBins');
    if (pgBins && pgBins.style.display !== 'none') renderBins();

    // 6. Update the topbar "Updated xx:xx" label
    document.getElementById('liveLabel').textContent = 'Updated ' + new Date().toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
  });

  sse.onerror = () => { sse.close(); sse = null; setTimeout(connectSSE, 5000); };
}

// ── ALERT POPUP ───────────────────────────────────────────────
function showAlertPopup(alert) {
  document.getElementById('_alertPopup')?.remove();
  const isfire = alert.kind === 'fire';
  const div = document.createElement('div');
  div.id = '_alertPopup';
  Object.assign(div.style, {
    position:'fixed', top:'20px', right:'20px', zIndex:'99999', width:'340px',
    background:'white', border:'2px solid ' + (isfire ? '#f97316' : '#dc2626'),
    borderRadius:'14px', padding:'18px 20px',
    boxShadow:'0 8px 32px rgba(220,38,38,.3)',
    animation:'slideIn .35s ease', fontFamily:'inherit'
  });

  const mapsHtml = alert.mapsLink
    ? `<a href="${alert.mapsLink}" target="_blank" style="font-size:12px;color:#2563eb;font-weight:600;text-decoration:none;display:block;margin-top:6px"><i class="fas fa-map"></i> Open in Google Maps</a>`
    : '';

  div.innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px">
      <div style="font-size:22px;line-height:1">${isfire ? '🔥' : '🗑️'}</div>
      <button id="_popupClose" style="background:none;border:none;font-size:20px;cursor:pointer;color:#9ca3af;line-height:1">×</button>
    </div>
    <div style="font-size:15px;font-weight:700;color:#111827;margin-bottom:6px">
      Dustbin ${alert.binId} is full, please clear it
    </div>
    <div style="font-size:13px;color:#374151;line-height:1.6;margin-bottom:8px">
      <div><i class="fas fa-map-marker-alt" style="color:#dc2626;margin-right:4px"></i>${alert.address || alert.location}</div>
      <div style="margin-top:2px">Fill level: <b style="color:#dc2626">${alert.level}%</b>${alert.lat ? '  ·  GPS: ' + alert.lat.toFixed(4) + ', ' + alert.lng.toFixed(4) : ''}</div>
    </div>
    ${mapsHtml}
    <div style="display:flex;gap:8px;margin-top:12px">
      <button id="_popupResolve" style="flex:1;background:#16a34a;color:white;border:none;border-radius:7px;padding:8px;font-size:13px;font-weight:600;cursor:pointer">
        <i class="fas fa-check"></i> Mark Resolved
      </button>
      <button id="_popupView" style="background:#f3f4f6;color:#374151;border:none;border-radius:7px;padding:8px 12px;font-size:13px;font-weight:600;cursor:pointer">
        View All
      </button>
    </div>`;

  document.body.appendChild(div);

  document.getElementById('_popupClose').onclick   = () => div.remove();
  document.getElementById('_popupView').onclick    = () => { goPage('alerts'); div.remove(); };
  document.getElementById('_popupResolve').onclick = async () => {
    div.remove();
    await resolveAlert(alert.id);
  };

  // Beep
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = ctx.createOscillator(), g = ctx.createGain();
    osc.connect(g); g.connect(ctx.destination);
    osc.frequency.setValueAtTime(880, ctx.currentTime);
    osc.frequency.setValueAtTime(660, ctx.currentTime + 0.15);
    g.gain.setValueAtTime(0.25, ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.5);
    osc.start(); osc.stop(ctx.currentTime + 0.5);
  } catch (_) {}

  setTimeout(() => document.getElementById('_alertPopup')?.remove(), 12000);
}

// ── BOOT ─────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  const u = getUser(), t = getToken();
  if (u && t && u.role === 'admin') bootApp(u);
});
</script>
</body>
</html>
